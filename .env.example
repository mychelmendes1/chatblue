# ==========================================
# Database
# ==========================================
DATABASE_URL="postgresql://chatblue:chatblue123@localhost:5432/chatblue"

# ==========================================
# Redis
# ==========================================
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# ==========================================
# JWT Authentication
# ==========================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ==========================================
# Server Configuration
# ==========================================
NODE_ENV="development"
API_PORT=3001
API_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# ==========================================
# Email (Brevo)
# ==========================================
# Get your API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=""
EMAIL_FROM="noreply@grupoblue.com.br"
EMAIL_FROM_NAME="ChatBlue"

# Alert recipients (comma-separated list of emails)
# These emails receive disconnection alerts and daily reports
ALERT_RECIPIENTS="email1@example.com,email2@example.com"

# Legacy SMTP (deprecated - use Brevo instead)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""

# ==========================================
# Push Notifications (Web Push / VAPID)
# Generate keys: npx web-push generate-vapid-keys
# ==========================================
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@chatblue.com"

# ==========================================
# Notion Integration
# ==========================================
NOTION_API_KEY=""
NOTION_DATABASE_ID=""

# ==========================================
# AI Providers
# ==========================================
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
AI_DEFAULT_MODEL="gpt-4-turbo-preview"

# ==========================================
# Meta WhatsApp Cloud API (Official)
# ==========================================
META_APP_ID=""
META_APP_SECRET=""
META_ACCESS_TOKEN=""
META_PHONE_NUMBER_ID=""
META_WEBHOOK_VERIFY_TOKEN=""

# ==========================================
# File Upload
# ==========================================
MAX_FILE_SIZE=10485760
UPLOADS_DIR="./uploads"

# ==========================================
# Encryption
# ==========================================
ENCRYPTION_KEY="your-32-character-encryption-key"

# ==========================================
# Docker Production (used by docker-compose.prod.yml)
# ==========================================
DB_USER="chatblue"
DB_PASSWORD="your-secure-db-password"
DB_NAME="chatblue"
