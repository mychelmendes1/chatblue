// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Plan {
  BASIC
  PRO
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  AGENT
}

enum ConnectionType {
  BAILEYS
  META_CLOUD
}

enum ConnectionStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  BANNED
  ERROR
}

enum TicketStatus {
  PENDING
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TransferType {
  USER_TO_USER
  DEPT_TO_DEPT
  AI_TO_HUMAN
  HUMAN_TO_AI
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  LOCATION
  CONTACT
  TEMPLATE
  INTERACTIVE
  SYSTEM
  REACTION
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  RECEIVED
}

enum ActivityType {
  TICKET_CREATED
  TICKET_ASSIGNED
  TICKET_TRANSFERRED
  TICKET_RESOLVED
  TICKET_CLOSED
  TICKET_REOPENED
  MESSAGE_SENT
  MESSAGE_RECEIVED
  AI_TAKEOVER
  HUMAN_TAKEOVER
  SLA_BREACH
  CONTACT_UPDATED
  NOTE_ADDED
  AI_ASSISTANT_QUERY
  AI_SUGGESTION_USED
  AI_SUGGESTION_EDITED
  AI_SUGGESTION_DISCARDED
}

// AI Data Source Types
enum AIDataSourceType {
  INTERNAL       // Base interna do sistema
  NOTION         // Integração Notion
  GOOGLE_DRIVE   // Google Drive
  CONFLUENCE     // Atlassian Confluence
  SHAREPOINT     // Microsoft SharePoint
  EXTERNAL_API   // APIs externas customizadas
  WEBSITE        // Web scraping
}

// AI Query Status
enum AIQueryStatus {
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// AI Document Status
enum AIDocumentStatus {
  PENDING        // Aguardando indexação
  INDEXING       // Em processo de indexação
  INDEXED        // Indexado com sucesso
  FAILED         // Falha na indexação
  OUTDATED       // Precisa reindexar
}

enum UserCompanyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserCompanyRole {
  ADMIN
  USER
}

// ============================================
// MODELS
// ============================================

/// Empresa (Tenant)
model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  plan      Plan     @default(BASIC)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users          User[]
  userAccess     UserCompany[]
  departments    Department[]
  connections    WhatsAppConnection[]
  contacts       Contact[]
  tickets        Ticket[]
  settings       CompanySettings?
  slaConfigs     SLAConfig[]
  knowledgeBase  KnowledgeBase[]
  faqs           FAQ[]

  // AI Assistant relations
  aiDataSources  AIDataSource[]
  aiAgentConfigs AIAgentConfig[]

  @@map("companies")
}

/// Usuário (Atendente ou Admin)
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  avatar    String?
  role      UserRole  @default(AGENT)
  isAI      Boolean   @default(false) @map("is_ai")
  aiConfig  Json?     @map("ai_config")
  isActive  Boolean   @default(true) @map("is_active")
  isOnline  Boolean   @default(false) @map("is_online")
  lastSeen  DateTime? @map("last_seen")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])

  departments      UserDepartment[]
  companyAccess    UserCompany[]    @relation("UserAccess")
  approvedAccess   UserCompany[]    @relation("ApprovedBy")
  tickets          Ticket[]         @relation("AssignedTickets")
  messages         Message[]
  activities       Activity[]

  // AI Assistant relations
  aiQueries AIAssistantQuery[]

  @@map("users")
}

/// Relacionamento Usuário-Empresa (Multi-empresa com aprovação)
model UserCompany {
  id        String            @id @default(cuid())
  userId    String            @map("user_id")
  user      User              @relation("UserAccess", fields: [userId], references: [id], onDelete: Cascade)
  companyId String            @map("company_id")
  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)

  role      UserCompanyRole   @default(USER)
  status    UserCompanyStatus @default(PENDING)

  approvedById String?   @map("approved_by_id")
  approvedBy   User?     @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime? @map("approved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, companyId])
  @@map("user_companies")
}

/// Departamento/Setor
model Department {
  id          String       @id @default(cuid())
  name        String
  description String?
  color       String?
  order       Int          @default(0)
  parentId    String?      @map("parent_id")
  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])

  users         UserDepartment[]
  tickets       Ticket[]
  slaConfig     SLAConfig?
  knowledgeBase KnowledgeBase[]
  faqs          FAQ[]

  // AI Assistant relations
  aiDocuments AIDocument[]

  @@map("departments")
}

/// Relação Usuário-Departamento
model UserDepartment {
  id           String     @id @default(cuid())
  userId       String     @map("user_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId String     @map("department_id")
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  isManager    Boolean    @default(false) @map("is_manager")

  @@unique([userId, departmentId])
  @@map("user_departments")
}

/// Conexão WhatsApp
model WhatsAppConnection {
  id     String           @id @default(cuid())
  name   String
  type   ConnectionType
  phone  String?
  status ConnectionStatus @default(DISCONNECTED)

  // Baileys specific
  qrCode      String? @map("qr_code")
  sessionData Json?   @map("session_data")

  // Meta Cloud API specific
  accessToken   String? @map("access_token")
  phoneNumberId String? @map("phone_number_id")
  businessId    String? @map("business_id")
  webhookToken  String? @map("webhook_token")

  isDefault     Boolean   @default(false) @map("is_default")
  isActive      Boolean   @default(true) @map("is_active")
  lastConnected DateTime? @map("last_connected")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])

  messages Message[]
  tickets  Ticket[]

  @@map("whatsapp_connections")
}

/// Contato
model Contact {
  id    String  @id @default(cuid())
  phone String
  name  String?
  email String?
  avatar String?
  
  // WhatsApp LID (Linked ID) - used when user has phone privacy enabled
  // This allows us to associate LIDs with real phone numbers
  lidId String? @map("lid_id")

  // Dados do Notion
  notionPageId String?   @map("notion_page_id")
  isClient     Boolean   @default(false) @map("is_client")
  isExClient   Boolean   @default(false) @map("is_ex_client")
  clientSince  DateTime? @map("client_since")

  tags         String[]
  notes        String?
  customFields Json?    @map("custom_fields")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Última mensagem recebida (para janela de 24h da API oficial)
  lastMessageAt DateTime? @map("last_message_at")

  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])

  tickets Ticket[]

  @@unique([phone, companyId])
  @@map("contacts")
}

/// Ticket (Conversa/Atendimento)
model Ticket {
  id       String       @id @default(cuid())
  protocol String       @unique
  status   TicketStatus @default(PENDING)
  priority Priority     @default(MEDIUM)
  subject  String?

  // SLA
  slaDeadline   DateTime? @map("sla_deadline")
  firstResponse DateTime? @map("first_response")
  resolvedAt    DateTime? @map("resolved_at")
  slaBreached   Boolean   @default(false) @map("sla_breached")

  // Métricas
  waitingTime    Int? @map("waiting_time")
  responseTime   Int? @map("response_time")
  resolutionTime Int? @map("resolution_time")

  // Avaliação do atendimento
  rating        Int?    @map("rating") // 1-5 estrelas
  ratingComment String? @map("rating_comment")
  ratedAt       DateTime? @map("rated_at")
  ratingToken   String? @unique @map("rating_token") // Token único para link de avaliação

  isAIHandled     Boolean   @default(false) @map("is_ai_handled")
  aiTakeoverAt    DateTime? @map("ai_takeover_at")
  humanTakeoverAt DateTime? @map("human_takeover_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  closedAt  DateTime? @map("closed_at")

  contactId String  @map("contact_id")
  contact   Contact @relation(fields: [contactId], references: [id])

  assignedToId String? @map("assigned_to_id")
  assignedTo   User?   @relation("AssignedTickets", fields: [assignedToId], references: [id])

  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])

  connectionId String             @map("connection_id")
  connection   WhatsAppConnection @relation(fields: [connectionId], references: [id])

  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])

  // Referência ao ticket anterior (para histórico visual)
  previousTicketId String?  @map("previous_ticket_id")
  previousTicket   Ticket?  @relation("TicketHistory", fields: [previousTicketId], references: [id])
  nextTickets      Ticket[] @relation("TicketHistory")

  messages   Message[]
  transfers  TicketTransfer[]
  activities Activity[]

  // AI Assistant relations
  aiQueries AIAssistantQuery[]

  @@index([companyId, status])
  @@index([assignedToId, status])
  @@index([departmentId, status])
  @@index([contactId, status])
  @@map("tickets")
}

/// Transferência de Ticket
model TicketTransfer {
  id       String @id @default(cuid())
  ticketId String @map("ticket_id")
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  fromUserId String? @map("from_user_id")
  toUserId   String? @map("to_user_id")
  fromDeptId String? @map("from_dept_id")
  toDeptId   String? @map("to_dept_id")

  reason       String?
  transferType TransferType @map("transfer_type")
  createdAt    DateTime     @default(now()) @map("created_at")

  @@map("ticket_transfers")
}

/// Mensagem
model Message {
  id        String      @id @default(cuid())
  wamid     String?
  type      MessageType @default(TEXT)
  content   String?
  mediaUrl  String?     @map("media_url")
  mediaType String?     @map("media_type")
  caption   String?
  transcription String? @db.Text // Transcrição de áudio/vídeo

  isFromMe      Boolean @default(false) @map("is_from_me")
  isAIGenerated Boolean @default(false) @map("is_ai_generated")
  isInternal    Boolean @default(false) @map("is_internal")
  mentionedUserIds String[] @map("mentioned_user_ids")

  status      MessageStatus @default(PENDING)
  sentAt      DateTime?     @map("sent_at")
  deliveredAt DateTime?     @map("delivered_at")
  readAt      DateTime?     @map("read_at")

  // Reações - JSON array de {emoji: string, userId: string, userName: string}
  reactions Json? @default("[]")

  // Metadados extras (localização, contatos, respostas interativas, etc)
  metadata Json? @default("{}")

  // Razão de falha no envio
  failedReason String? @map("failed_reason")

  // Mensagem deletada
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by") // userId que deletou

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ticketId String @map("ticket_id")
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  senderId String? @map("sender_id")
  sender   User?   @relation(fields: [senderId], references: [id])

  connectionId String             @map("connection_id")
  connection   WhatsAppConnection @relation(fields: [connectionId], references: [id])

  // Referência a mensagem citada (reply)
  quotedId String?   @map("quoted_id")
  quoted   Message?  @relation("QuotedMessage", fields: [quotedId], references: [id])
  replies  Message[] @relation("QuotedMessage")

  @@index([ticketId, createdAt])
  @@map("messages")
}

/// Configuração de SLA
model SLAConfig {
  id   String @id @default(cuid())
  name String

  // Tempos em minutos
  firstResponseTime Int @default(15) @map("first_response_time")
  resolutionTime    Int @default(240) @map("resolution_time")

  // Horário de funcionamento
  businessHours Json? @map("business_hours")

  isDefault Boolean  @default(false) @map("is_default")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])

  departmentId String?     @unique @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])

  @@map("sla_configs")
}

/// Atividade/Log
model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  description String
  metadata    Json?
  createdAt   DateTime     @default(now()) @map("created_at")

  ticketId String? @map("ticket_id")
  ticket   Ticket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  @@index([ticketId, createdAt])
  @@map("activities")
}

/// Configurações da Empresa
model CompanySettings {
  id String @id @default(cuid())

  // Notion Integration
  notionApiKey      String? @map("notion_api_key")
  notionDatabaseId  String? @map("notion_database_id")
  notionSyncEnabled Boolean @default(false) @map("notion_sync_enabled")

  // AI Settings
  aiEnabled      Boolean @default(false) @map("ai_enabled")
  aiProvider     String? @map("ai_provider")
  aiApiKey       String? @map("ai_api_key")
  aiDefaultModel String? @map("ai_default_model")
  aiSystemPrompt String? @map("ai_system_prompt")

  // Whisper (Audio Transcription) - Uses OpenAI API
  whisperApiKey  String? @map("whisper_api_key")

  // AI Personality Settings
  aiPersonalityTone     String? @map("ai_personality_tone") // friendly, formal, technical, empathetic
  aiPersonalityStyle    String? @map("ai_personality_style") // concise, detailed, conversational
  aiUseEmojis           Boolean @default(true) @map("ai_use_emojis")
  aiUseClientName       Boolean @default(true) @map("ai_use_client_name")
  aiGuardrailsEnabled   Boolean @default(true) @map("ai_guardrails_enabled")

  // Outras configurações
  autoAssign         Boolean @default(true) @map("auto_assign")
  maxTicketsPerAgent Int     @default(10) @map("max_tickets_per_agent")
  welcomeMessage     String? @map("welcome_message")
  awayMessage        String? @map("away_message")

  // Default department for transfers when no specific department is found
  defaultTransferDepartmentId String? @map("default_transfer_department_id")

  companyId String  @unique @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("company_settings")
}

/// Base de Conhecimento
model KnowledgeBase {
  id       String  @id @default(cuid())
  title    String
  content  String  @db.Text
  category String?
  tags     String[]
  order    Int     @default(0)

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])

  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])

  @@index([companyId, isActive])
  @@index([departmentId, isActive])
  @@map("knowledge_base")
}

/// Perguntas Frequentes (FAQ)
model FAQ {
  id       String   @id @default(cuid())
  question String
  answer   String   @db.Text
  keywords String[]
  category String?
  order    Int      @default(0)

  useCount  Int      @default(0) @map("use_count")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])

  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])

  @@index([companyId, isActive])
  @@index([departmentId, isActive])
  @@map("faqs")
}

// ============================================
// AI ASSISTANT MODELS
// ============================================

/// Fonte de Dados para IA (Notion, Google Drive, Confluence, etc)
model AIDataSource {
  id          String           @id @default(cuid())
  name        String           // "Produtos", "Políticas", "Procedimentos"
  type        AIDataSourceType
  description String?

  // Configuração específica por tipo (JSON)
  // Notion: { databaseId, titleProperty, contentProperty, filters }
  // Google Drive: { folderId, credentials }
  // Confluence: { spaceKey, baseUrl, credentials }
  // External API: { url, headers, method, bodyTemplate }
  config Json @default("{}")

  // Organização
  category String?  // "vendas", "suporte", "financeiro", "produtos"
  tags     String[]
  priority Int      @default(0) // Ordem de busca (maior = prioridade maior)

  // Ícone e cor para UI
  icon  String? // Nome do ícone Lucide
  color String? // Cor hexadecimal

  // Controle de sincronização
  syncEnabled   Boolean   @default(true) @map("sync_enabled")
  syncInterval  Int       @default(60) @map("sync_interval") // minutos
  lastSyncAt    DateTime? @map("last_sync_at")
  lastSyncError String?   @map("last_sync_error")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])

  documents AIDocument[]

  // Relação com IAs que usam esta fonte
  agentConfigs AIAgentDataSource[]

  @@index([companyId, isActive])
  @@index([companyId, type])
  @@map("ai_data_sources")
}

/// Documento indexado para busca semântica
model AIDocument {
  id      String  @id @default(cuid())
  title   String
  content String  @db.Text
  summary String? @db.Text // Resumo gerado por IA para busca rápida

  // Metadados para organização e busca
  category String?
  tags     String[]
  keywords String[] // Palavras-chave extraídas automaticamente

  // Referência externa (para sync)
  externalId  String? @map("external_id") // ID no Notion, Google Drive, etc
  externalUrl String? @map("external_url") // Link para documento original
  checksum    String? // Hash do conteúdo para detectar mudanças

  // Embedding para busca semântica (vetor de 1536 dimensões para OpenAI, 1024 para Anthropic)
  embedding     Float[] // Vetor de embedding
  embeddingModel String? @map("embedding_model") // Modelo usado para gerar embedding

  // Status de indexação
  status         AIDocumentStatus @default(PENDING)
  indexedAt      DateTime?        @map("indexed_at")
  indexError     String?          @map("index_error")
  tokensCount    Int?             @map("tokens_count") // Quantidade de tokens do documento

  dataSourceId String       @map("data_source_id")
  dataSource   AIDataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])

  companyId String @map("company_id")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Uso nos queries
  queryReferences AIQuerySource[]

  @@index([companyId, isActive, status])
  @@index([dataSourceId])
  @@index([externalId])
  @@map("ai_documents")
}

/// Configuração de IA por Categoria
model AIAgentConfig {
  id   String @id @default(cuid())
  name String // "IA de Vendas", "IA de Suporte", "IA Financeira"

  // Categoria que esta IA atende
  category    String  // "vendas", "suporte", "financeiro", "produtos", "geral"
  description String?

  // Prompts específicos
  systemPrompt String @db.Text @map("system_prompt")

  // Configuração do modelo
  provider    String // openai, anthropic
  model       String // gpt-4o, claude-sonnet-4
  temperature Float  @default(0.7)
  maxTokens   Int    @default(1500) @map("max_tokens")

  // Personalidade
  tone  String? // friendly, formal, technical, empathetic
  style String? // concise, detailed, conversational

  // Regras e restrições (JSON)
  // { maxResponseLength, forbiddenTopics, requiredDisclaimer, etc }
  rules Json @default("{}")

  // Keywords que ativam esta IA (para roteamento automático)
  triggerKeywords String[] @map("trigger_keywords")

  // Prioridade (maior = escolhida primeiro se houver empate)
  priority Int @default(0)

  // Ícone e cor para UI
  icon  String? // Nome do ícone Lucide
  color String? // Cor hexadecimal

  isActive  Boolean  @default(true) @map("is_active")
  isDefault Boolean  @default(false) @map("is_default") // IA padrão quando nenhuma categoria match

  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Fontes de dados que esta IA pode consultar
  dataSources AIAgentDataSource[]

  // Queries processadas por esta IA
  queries AIAssistantQuery[]

  @@unique([companyId, category])
  @@index([companyId, isActive])
  @@map("ai_agent_configs")
}

/// Relação N:N entre AIAgentConfig e AIDataSource
model AIAgentDataSource {
  id String @id @default(cuid())

  agentConfigId String        @map("agent_config_id")
  agentConfig   AIAgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  dataSourceId String       @map("data_source_id")
  dataSource   AIDataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  // Peso/prioridade desta fonte para este agente
  weight Int @default(1)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([agentConfigId, dataSourceId])
  @@map("ai_agent_data_sources")
}

/// Histórico de Consultas @ia
model AIAssistantQuery {
  id String @id @default(cuid())

  // Query original
  query   String  @db.Text // Pergunta do atendente
  context String? @db.Text // Contexto da conversa (últimas mensagens)

  // Resposta gerada
  response       String  @db.Text // Resposta gerada pela IA
  editedResponse String? @db.Text @map("edited_response") // Resposta após edição do atendente

  // Categoria detectada
  detectedCategory String? @map("detected_category")
  categoryConfidence Float? @map("category_confidence")

  // Status do processamento
  status AIQueryStatus @default(PROCESSING)

  // Métricas de performance
  processingTime  Int? @map("processing_time") // ms
  tokensInput     Int? @map("tokens_input")
  tokensOutput    Int? @map("tokens_output")
  embeddingTime   Int? @map("embedding_time") // ms para gerar embedding da query
  searchTime      Int? @map("search_time") // ms para buscar documentos

  // Uso e feedback
  wasUsed        Boolean   @default(false) @map("was_used") // Se foi enviada ao cliente
  wasEdited      Boolean   @default(false) @map("was_edited")
  usedAt         DateTime? @map("used_at")

  // Rating do atendente (1-5)
  rating         Int?      @map("rating")
  ratingComment  String?   @map("rating_comment")
  ratedAt        DateTime? @map("rated_at")

  // Detecção de gap (se a IA não soube responder)
  hasKnowledgeGap Boolean @default(false) @map("has_knowledge_gap")
  gapDescription  String? @map("gap_description")

  // Relações
  ticketId String @map("ticket_id")
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  userId String @map("user_id") // Atendente que consultou
  user   User   @relation(fields: [userId], references: [id])

  agentConfigId String?        @map("agent_config_id") // IA que processou
  agentConfig   AIAgentConfig? @relation(fields: [agentConfigId], references: [id])

  companyId String @map("company_id")

  createdAt DateTime @default(now()) @map("created_at")

  // Fontes usadas na resposta
  sourcesUsed AIQuerySource[]

  @@index([ticketId])
  @@index([userId])
  @@index([companyId, createdAt])
  @@index([companyId, hasKnowledgeGap])
  @@map("ai_assistant_queries")
}

/// Fontes usadas em uma query (para rastreabilidade)
model AIQuerySource {
  id String @id @default(cuid())

  queryId String           @map("query_id")
  query   AIAssistantQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)

  documentId String     @map("document_id")
  document   AIDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Score de relevância (0-1)
  relevanceScore Float @map("relevance_score")

  // Trecho usado do documento
  usedExcerpt String? @db.Text @map("used_excerpt")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([queryId])
  @@map("ai_query_sources")
}

/// Gaps de Conhecimento Detectados
model AIKnowledgeGap {
  id String @id @default(cuid())

  // Descrição do gap
  topic       String // Tópico/assunto que falta
  description String @db.Text
  frequency   Int    @default(1) // Quantas vezes foi detectado

  // Exemplos de queries que geraram o gap
  sampleQueries String[] @map("sample_queries")

  // Sugestão de categoria/fonte onde adicionar
  suggestedCategory   String? @map("suggested_category")
  suggestedDataSource String? @map("suggested_data_source")

  // Status
  status    String   @default("pending") // pending, in_progress, resolved, dismissed
  resolvedAt DateTime? @map("resolved_at")
  resolvedBy String?   @map("resolved_by")

  companyId String @map("company_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId, status])
  @@map("ai_knowledge_gaps")
}

/// Sugestões Automáticas (respostas sugeridas sem @ia)
model AIAutoSuggestion {
  id String @id @default(cuid())

  // Mensagem que triggou a sugestão
  triggerMessage String @db.Text @map("trigger_message")

  // Sugestão gerada
  suggestion String @db.Text

  // Categoria detectada
  category   String?
  confidence Float?

  // Se foi aceita/usada
  wasAccepted Boolean   @default(false) @map("was_accepted")
  wasEdited   Boolean   @default(false) @map("was_edited")
  acceptedAt  DateTime? @map("accepted_at")

  // Relações
  ticketId String @map("ticket_id")

  userId String? @map("user_id") // Atendente que recebeu

  companyId String @map("company_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([ticketId])
  @@index([companyId, createdAt])
  @@map("ai_auto_suggestions")
}

/// Análise de Sentimento das Conversas
model AISentimentAnalysis {
  id String @id @default(cuid())

  // Análise
  sentiment String // positive, negative, neutral
  score     Float  // -1 a 1

  // Emoções detectadas
  emotions Json? // { joy: 0.8, anger: 0.1, sadness: 0.1 }

  // Urgência detectada
  urgency      String? // low, medium, high, critical
  urgencyScore Float?  @map("urgency_score")

  // Intenção principal
  intent          String? // question, complaint, purchase, support, etc
  intentConfidence Float? @map("intent_confidence")

  // Palavras-chave detectadas
  keywords String[]

  // Mensagem analisada
  messageId String @map("message_id")

  ticketId String @map("ticket_id")

  companyId String @map("company_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([ticketId])
  @@index([companyId, sentiment])
  @@map("ai_sentiment_analyses")
}
